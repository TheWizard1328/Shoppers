{
  "name": "DemoSettings",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "The current app user's id"
    },
    "is_demo_mode_active": {
      "type": "boolean",
      "default": false,
      "description": "Whether demo mode is currently active for this user"
    },
    "demo_store_id": {
      "type": "string",
      "description": "Active demo store id for this user"
    }
  },
  "required": [
    "user_id"
  ]
}
{
  "name": "PendingBreadcrumbLive",
  "type": "object",
  "properties": {
    "driver_id": {
      "type": "string",
      "description": "ID of the driver this live breadcrumb batch belongs to"
    },
    "delivery_date": {
      "type": "string",
      "format": "date",
      "description": "Route date for these live breadcrumbs (YYYY-MM-DD)"
    },
    "points": {
      "type": "array",
      "description": "Live GPS breadcrumb points captured before consolidation",
      "items": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "timestamp": {
            "type": "number",
            "description": "Unix timestamp in milliseconds"
          }
        },
        "required": [
          "latitude",
          "longitude",
          "timestamp"
        ]
      }
    }
  },
  "required": [
    "driver_id",
    "delivery_date"
  ]
}
{
  "name": "DemoAppUser",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "app_roles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["admin", "driver", "dispatcher", "patient"]
      },
      "default": ["driver"]
    },
    "user_name": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "home_latitude": {
      "type": "number"
    },
    "home_longitude": {
      "type": "number"
    },
    "city_id": {
      "type": "string"
    },
    "city_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "store_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sort_order": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive"],
      "default": "active"
    },
    "driver_status": {
      "type": "string",
      "enum": ["off_duty", "on_duty", "on_break", "online"],
      "default": "on_duty"
    },
    "location_tracking_enabled": {
      "type": "boolean",
      "default": true
    },
    "current_latitude": {
      "type": "number"
    },
    "current_longitude": {
      "type": "number"
    },
    "location_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "pay_rate_per_delivery": {
      "type": "number"
    },
    "extra_km_rate": {
      "type": "number"
    },
    "extra_km_limit": {
      "type": "number"
    },
    "oversized_item_rate": {
      "type": "number"
    },
    "gst_hst_enabled": {
      "type": "boolean",
      "default": false
    },
    "pay_cycle_type": {
      "type": "string",
      "enum": ["weekly", "biweekly", "semimonthly", "monthly"],
      "default": "monthly"
    },
    "is_demo": {
      "type": "boolean",
      "default": true
    }
  },
  "required": ["user_id", "app_roles", "user_name"]
}
{
  "name": "RemoteLogEntry",
  "type": "object",
  "properties": {
    "level": {
      "type": "string",
      "enum": ["log", "info", "warn", "error", "debug"],
      "description": "Console log level"
    },
    "message": {
      "type": "string",
      "description": "Log message text"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the log was created on the device"
    },
    "user_id": {
      "type": "string",
      "description": "Authenticated user ID if available"
    },
    "user_name": {
      "type": "string",
      "description": "App user name if available"
    },
    "device_identifier": {
      "type": "string",
      "description": "Stable device identifier"
    },
    "device_type": {
      "type": "string",
      "description": "Device type"
    },
    "os": {
      "type": "string",
      "description": "Operating system"
    },
    "page": {
      "type": "string",
      "description": "Current page path"
    },
    "session_id": {
      "type": "string",
      "description": "Browser session identifier"
    },
    "metadata": {
      "type": "object",
      "description": "Extra structured log metadata",
      "additionalProperties": true
    }
  },
  "required": ["level", "message", "timestamp"]
}